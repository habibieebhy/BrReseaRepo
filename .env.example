# =========================================================
# PRODUCTION DATABASE
# =========================================================
DATABASE_URL=PASTE_ROTATED_NEON_DATABASE_URL


# =========================================================
# PRODUCTION REDIS
# Generate with: openssl rand -hex 32
# Paste the same generated value in both places.
# =========================================================
REDIS_PASSWORD=PASTE_GENERATED_REDIS_PASSWORD
REDIS_URL=redis://:PASTE_SAME_REDIS_PASSWORD@redis-service.brixta.svc.cluster.local:6379/0


# =========================================================
# PRODUCTION MINIO
# Generate two different passwords using:
# openssl rand -hex 32
# =========================================================
ARTIFACT_BACKEND=minio
MINIO_ENDPOINT=minio-service.brixta.svc.cluster.local:9000

# Leave blank until you intentionally expose and protect the console.
MINIO_CONSOLE_URL=

MINIO_ROOT_USER=brixta-root
MINIO_ROOT_PASSWORD=PASTE_GENERATED_MINIO_ROOT_PASSWORD

MINIO_ACCESS_KEY=brixta-app
MINIO_SECRET_KEY=PASTE_DIFFERENT_GENERATED_MINIO_APP_PASSWORD

MINIO_BUCKET=brixta
MINIO_SECURE=false


# =========================================================
# EMBEDDINGS AND PARSING
# =========================================================
EMBEDDING_PLUGIN=sentence-transformers
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5

BRIXTA_DOCLING_DEVICE=cpu
BRIXTA_DOCLING_THREADS=4

# Recommended for production Hugging Face downloads.
HF_TOKEN=PASTE_HUGGINGFACE_TOKEN


# =========================================================
# PRODUCTION PUBLIC ADDRESSES
# =========================================================
BRIXTA_API_PUBLIC_URL=https://brixta.brixtahomeserver.site/api/core
BRIXTA_DASHBOARD_PUBLIC_URL=https://brixta.brixtahomeserver.site
BRIXTA_MCP_PUBLIC_URL=https://brixta-mcp.brixtahomeserver.site/mcp


# =========================================================
# PRODUCTION MCP JWT AUTHENTICATION
# =========================================================
BRIXTA_MCP_AUTH_MODE=jwt

BRIXTA_MCP_JWKS_URI=https://YOUR_AUTH0_DOMAIN/.well-known/jwks.json
BRIXTA_MCP_JWT_ISSUER=https://YOUR_AUTH0_DOMAIN/
BRIXTA_MCP_JWT_AUDIENCE=https://brixta-mcp.brixtahomeserver.site/mcp
BRIXTA_MCP_JWT_ALGORITHM=RS256
BRIXTA_MCP_TENANT_CLAIM=tenant_id

BRIXTA_KNOWLEDGE_ACCESS_BACKEND=postgres
BRIXTA_CHATGPT_DISTRIBUTION=developer
BRIXTA_CHATGPT_CONNECT_URL=https://chatgpt.com/plugins


# =========================================================
# JOB RECOVERY
# =========================================================
MAX_TASK_ATTEMPTS=3
TASK_RETRY_BACKOFF_SECONDS=15
ORPHAN_TIMEOUT_SECONDS=1800
MAX_JOB_RUNS=3


# =========================================================
# SIMULATIONS
# =========================================================
CALCULIX_EXECUTABLE=ccx
OPENFOAM_BLOCKMESH_EXECUTABLE=blockMesh
OPENFOAM_CHECKMESH_EXECUTABLE=checkMesh
OPENFOAM_RUN_EXECUTABLE=foamRun
OPENFOAM_VTK_EXECUTABLE=foamToVTK
SIMULATION_TIMEOUT_SECONDS=1800


# =========================================================
# LOGGING
# =========================================================
LOG_LEVEL=INFO